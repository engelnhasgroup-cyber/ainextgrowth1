// NexusAI 2026 — AI Prompt & Skill Library
// Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Item {
  id              String   @id @default(cuid())
  slug            String   @unique
  type            String   // "prompt" | "skill" | "workflow"
  title           String
  summary         String
  category        String
  niche           String
  audience        String
  difficulty      String   // Beginner | Intermediate | Advanced | Expert
  language        String   @default("English")

  // SEO intro (~200 words) — AdSense/SEO requirement, rendered on-page
  intro           String   @default("")

  // Trinity Bundle content (Markdown)
  promptContent   String   // File 1: The Prompt / Skill / Workflow definition
  workflowContent String   // File 2: Workflow & Execution
  audienceContent String   // File 3: Target Audience & Use Cases

  // Comma/pipe separated (SQLite primitives can't be lists)
  tags            String   @default("")
  requiredTools   String   @default("")
  useCases        String   @default("")

  // Trending & curation
  trending        Boolean  @default(false)
  trendingScore   Int      @default(0)
  featured        Boolean  @default(false)

  // Engagement signals
  viewCount       Int      @default(0)
  downloadCount   Int      @default(0)
  rating          Float    @default(5.0)

  // SEO / GEO / AEO fields
  faqQuestion     String   @default("")
  faqAnswer       String   @default("")
  citation        String   @default("")
  seoKeywords     String   @default("")

  // E-E-A-T: human editorial review attribution (AdSense trust signal)
  reviewedBy      String   @default("NexusAI Editorial Team")
  publishedAt     DateTime? @default(now())

  // Internal linking graph (comma separated item ids)
  relatedIds      String   @default("")

  // Generation provenance
  source          String   @default("seed") // "seed" | "agent"
  runDate         String   @default("")     // YYYY-MM-DD of generation

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([trending])
  @@index([featured])
  @@index([slug])
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  color       String
  createdAt   DateTime @default(now())
}

model GenerationLog {
  id           String   @id @default(cuid())
  runDate      String   // YYYY-MM-DD
  promptsCount Int      @default(0)
  skillsCount  Int      @default(0)
  status       String   @default("completed")
  note         String   @default("")
  createdAt    DateTime @default(now())

  @@index([runDate])
}

model Lead {
  id          String   @id @default(cuid())
  email       String?  @unique
  phone       String?  @unique
  channel     String   @default("whatsapp") // "whatsapp" | "email" | "both"
  subscribed  Boolean  @default(true)
  countryCode String   @default("")
  source      String   @default("footer")   // "footer" | "floating" | "dashboard"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channel])
  @@index([subscribed])
  @@index([email])
  @@index([phone])
}

model ErrorLog {
  id          String   @id @default(cuid())
  source      String   // "cron" | "api" | "agent" | "broadcast"
  endpoint    String   @default("")
  message     String
  stack       String   @default("")
  severity    String   @default("error") // "error" | "warn" | "info"
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
}

model CronJobLog {
  id          String   @id @default(cuid())
  jobName     String   // "daily-generation" | "seo-agent" | "send-email-digest" | "send-whatsapp-digest"
  status      String   @default("completed") // "completed" | "failed" | "running"
  duration    Int      @default(0)           // milliseconds
  itemsAffected Int    @default(0)
  message     String   @default("")
  createdAt   DateTime @default(now())

  @@index([jobName])
  @@index([status])
  @@index([createdAt])
}

model AdminSetting {
  id                      String   @id @default("singleton")
  googleVerificationCode  String   @default("")
  bingVerificationCode    String   @default("")
  yandexVerification      String   @default("")
  baiduVerification       String   @default("")
  googleAnalyticsId       String   @default("")
  adsenseClientId         String   @default("ca-pub-XXXXXXXXXXXXXXXX")
  aiSystemPrompt          String   @default("You are the ainextgrowth Autonomous Content Agent. Generate professional, 2026-era AI prompts, skills, and workflows with full Trinity Bundles.")
  aiDailyLimit            Int      @default(200)
  siteName                String   @default("ainextgrowth")
  siteUrl                 String   @default("https://ainextgrowth.com")
  maintenanceMode         Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model SocialIntegration {
  id            String   @id @default(cuid())
  platform      String   @unique // "twitter" | "linkedin" | "reddit" | "telegram"
  connected     Boolean  @default(false)
  apiKey        String   @default("")  // encrypted in production
  apiSecret     String   @default("")
  accessToken   String   @default("")
  autoPost     Boolean  @default(true)
  lastPostedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([platform])
}

model Article {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  metaDescription String   @default("")
  keywords        String   @default("")   // comma-separated
  category        String   @default("AI")
  content         String   @default("")   // Markdown (1500-2000 words)
  tableOfContents String   @default("[]") // JSON array of {id, text, level}
  author          String   @default("NexusAI Editorial Team")
  readingTime     Int      @default(5)
  faqs            String   @default("[]") // JSON array of {question, answer}
  featured        Boolean  @default(false)
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([featured])
  @@index([publishedAt])
}
